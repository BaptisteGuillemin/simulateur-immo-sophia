{
  "name": "simulateur-immo-mcp",
  "version": "1.0.0",
  "description": "Serveur MCP stdio qui expose le moteur de simulation immobilière Sophia Antipolis (mensualités, paliers HCSF, PTZ, aides primo-accédant, comparaison communes) à Claude Desktop / Claude Code.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "claude-code",
    "immobilier",
    "simulateur",
    "sophia-antipolis",
    "primo-accedant",
    "ptz",
    "hcsf"
  ],
  "type": "module",
  "private": true,
  "bin": {
    "simulateur-immo-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "smoke": "printf '%s\\n' '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2024-11-05\",\"capabilities\":{},\"clientInfo\":{\"name\":\"smoke\",\"version\":\"0\"}}}' '{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\"}' '{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/list\"}' | tsx src/index.ts 2>/dev/null | head -3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
