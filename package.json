    "url": "git+https://github.com/BaptisteGuillemin/simulateur-immo-sophia.git"
  },
  "bugs": {
    "url": "https://github.com/BaptisteGuillemin/simulateur-immo-sophia/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
